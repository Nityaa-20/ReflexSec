# =============================================================
#  ReflexSec — Environment Variable Reference
#  Copy this file to .env and fill in all required values.
#  NEVER commit the actual .env file to version control.
# =============================================================


# ─────────────────────────────────────────
#  FASTAPI APPLICATION
# ─────────────────────────────────────────

# Human-readable name shown in API docs / logs
APP_NAME=ReflexSec

# Runtime environment: development | staging | production
APP_ENV=production

# Enable debug mode (never true in production)
DEBUG=false

# Frontend origin allowed by CORS (comma-separated for multiple)
VITE_API_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000


# ─────────────────────────────────────────
#  POSTGRESQL
# ─────────────────────────────────────────

POSTGRES_DB=reflexsec
POSTGRES_USER=reflexsec_user

# REQUIRED — set a strong, unique password
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# Full async DSN used by SQLAlchemy / asyncpg
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<db>
DATABASE_URL=postgresql+asyncpg://reflexsec_user:CHANGE_ME_strong_password_here@postgres:5432/reflexsec

# Connection pool tuning
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30


# ─────────────────────────────────────────
#  REDIS
# ─────────────────────────────────────────

# Leave REDIS_PASSWORD blank to disable Redis AUTH (not recommended in production)
REDIS_PASSWORD=CHANGE_ME_redis_password_here

# Full Redis DSN — used by the backend and task workers
# Format: redis://:<password>@<host>:<port>/<db_index>
REDIS_URL=redis://:CHANGE_ME_redis_password_here@redis:6379/0

# Cache TTL for threat intel results (seconds)
REDIS_CACHE_TTL=3600


# ─────────────────────────────────────────
#  OLLAMA  (Local LLM Inference)
# ─────────────────────────────────────────

# Internal service URL (Docker service name)
OLLAMA_BASE_URL=http://ollama:11434

# Model to use for threat analysis and self-critique
# Examples: llama3, mistral, mixtral, phi3, gemma2
OLLAMA_MODEL=llama3

# Max concurrent inference requests
OLLAMA_NUM_PARALLEL=2

# How long to keep a loaded model in memory (e.g. 24h, 30m, 0 = unload immediately)
OLLAMA_KEEP_ALIVE=24h

# Request timeout in seconds
OLLAMA_TIMEOUT=120


# ─────────────────────────────────────────
#  SECURITY / JWT
# ─────────────────────────────────────────

# REQUIRED — generate with: openssl rand -hex 64
JWT_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_64

# Signing algorithm — HS256 recommended; use RS256 for asymmetric keys
JWT_ALGORITHM=HS256

# Access token lifetime in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token lifetime in days
REFRESH_TOKEN_EXPIRE_DAYS=7

# Bcrypt hashing rounds (12–14 recommended for production)
PASSWORD_HASH_ROUNDS=12


# ─────────────────────────────────────────
#  LOGGING
# ─────────────────────────────────────────

# Log verbosity: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Log output format: json | text
LOG_FORMAT=json

# Rotate logs when they exceed this size (bytes)
LOG_MAX_BYTES=10485760

# Number of rotated log files to retain
LOG_BACKUP_COUNT=5


# ─────────────────────────────────────────
#  THREAT INTELLIGENCE (optional integrations)
# ─────────────────────────────────────────

# VirusTotal API key
VT_API_KEY=

# AbuseIPDB API key
ABUSEIPDB_API_KEY=

# Shodan API key
SHODAN_API_KEY=

# AlienVault OTX API key
OTX_API_KEY=


# ─────────────────────────────────────────
#  FEATURE FLAGS
# ─────────────────────────────────────────

# Enable the self-critique / second-pass LLM review loop
ENABLE_SELF_CRITIQUE=true

# Maximum critique iterations before returning a final answer
MAX_CRITIQUE_ITERATIONS=3

# Minimum confidence score (0.0–1.0) required before returning a result
MIN_CONFIDENCE_THRESHOLD=0.75
